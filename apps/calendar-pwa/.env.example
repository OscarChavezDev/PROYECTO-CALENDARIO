# Variables frontend-safe (Vite expone al navegador todo lo que empiece con VITE_)
# Copiar a .env.local y llenar con los valores del proyecto Supabase.
# NUNCA poner aquí la service role key ni otros secrets de servidor.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Web Push: clave PÚBLICA VAPID (frontend-safe). La privada va en Supabase, no aquí.
# Generar con: npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=
